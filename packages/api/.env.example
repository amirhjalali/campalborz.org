# Database
DATABASE_URL="postgresql://username:password@localhost:5432/camp_platform"

# JWT Secret
JWT_SECRET="your-super-secret-jwt-key-here"

# Server Configuration
PORT=3005
HOST=0.0.0.0
NODE_ENV=development

# CORS / Frontend origin(s)
# FRONTEND_URL: single allowed web origin (simplest case).
# CORS_ORIGIN:  comma-separated list; takes precedence over FRONTEND_URL when set.
# If neither is set, dev defaults to http://localhost:3006,http://localhost:3000
# and production defaults to https://campalborz.org,https://www.campalborz.org.
FRONTEND_URL="http://localhost:3006"
CORS_ORIGIN="http://localhost:3006,http://localhost:3000"

# Platform Configuration
PLATFORM_DOMAIN="localhost:3000"
PLATFORM_NAME="Camp Management Platform"

# Email Configuration
# Option 1: SendGrid (preferred) — set SENDGRID_API_KEY
SENDGRID_API_KEY=""

# Option 2: SMTP via Nodemailer — set all four SMTP_* variables
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASS=""

# Shared email settings
EMAIL_FROM="Camp Alborz <noreply@campalborz.org>"
APP_URL="http://localhost:3006"

# Payment Processing (Stripe)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# File Storage
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION=""
AWS_S3_BUCKET=""