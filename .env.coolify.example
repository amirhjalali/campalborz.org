# Camp Alborz - Coolify Environment Variables
# Copy this to your Coolify service environment settings

# === REQUIRED ===

# Database (auto-configured if using Coolify's PostgreSQL)
DATABASE_URL=postgresql://campalborz:CHANGE_ME@db:5432/campalborz
POSTGRES_USER=campalborz
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=campalborz

# JWT secret for authentication (generate with: openssl rand -hex 32)
JWT_SECRET=CHANGE_ME

# === WEB URLS ===

# Your public domain
APP_URL=https://campalborz.org
NEXT_PUBLIC_API_URL=https://campalborz.org/api
NEXT_PUBLIC_WS_URL=wss://campalborz.org

# === EMAIL (choose one) ===

# Option A: SendGrid
SENDGRID_API_KEY=

# Option B: SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

EMAIL_FROM=Camp Alborz <noreply@campalborz.org>

# === PAYMENTS (optional) ===
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# === FEATURES ===
NEXT_PUBLIC_ENABLE_DONATIONS=true
NEXT_PUBLIC_ENABLE_APPLICATIONS=true
